# ============================================================
#  Kho Prompt N-Edit — Biến môi trường
#  Copy file này thành .env rồi điền giá trị thật.
#  (KHÔNG commit file .env lên git — chỉ commit .env.example)
# ============================================================

# --- Supabase (nơi lưu prompt của cả team) ---------------------------------
# Lấy ở: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# --- Backend AI ("Nhờ AI viết giúp") ---------------------------------------
# Đã có sẵn serverless function tại api/suggest-prompt.ts.
# Bình thường KHÔNG cần đặt biến này (mặc định gọi /api/suggest-prompt).
# Chỉ đặt nếu muốn trỏ sang endpoint khác.
# VITE_AI_API_URL=/api/suggest-prompt

# ============================================================
#  Biến CHỈ dùng ở server (KHÔNG có tiền tố VITE_, KHÔNG lộ ra frontend).
#  Trên Vercel: thêm ở Project Settings → Environment Variables.
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-xxxxx                     # BẮT BUỘC để "Nhờ AI viết giúp" chạy thật
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key    # nếu backend cần ghi/đọc bảo mật
